# העתק ל-.env ומלא ערכים אמיתיים (אל תעלה את .env לגיט)

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
# מודל הבוט. מתחילים זול ומהיר; משדרגים ל-claude-sonnet-4-6 אם צריך איכות גבוהה יותר
BOT_MODEL=claude-haiku-4-5-20251001

# שרת
PORT=3000
# מפתח פשוט שמגן על ה-webhook (Make/Wizup ישלחו אותו בכותרת x-bot-secret)
WEBHOOK_SECRET=change-me-to-a-long-random-string

# Fireberry (CRM) — למילוי כשמחברים את העדכון חזרה ל-CRM
FIREBERRY_API_TOKEN=
FIREBERRY_BASE_URL=https://api.fireberry.com

# Meta WhatsApp Cloud API (חיבור ישיר, בלי Wizup)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# טוקן שאתה ממציא — תזין אותו גם במסך הגדרת ה-webhook ב-Meta
WHATSAPP_VERIFY_TOKEN=cmtm-verify-7421

# קישורים ששולחים ללידים
LINK_TASTE_LESSON=https://cmtm.co.il/lp-lesson-may-mo/
LINK_WEBINAR=https://cmtm.co.il/free-lessons/
